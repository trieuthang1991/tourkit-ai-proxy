appsettings.json

# Claude Code local state (per-machine permissions)
.claude/settings.local.json

# Runtime-generated review cache (re-populated by AI calls)
data/reviews.json

# Phiên đăng nhập TourKit (chứa credentials mã hóa) — KHÔNG commit
data/tk-sessions.json

# API key provider nhập từ UI (mã hóa) — KHÔNG commit
data/provider-keys.json

# SmartMail AI — hộp thư cache + creds Gmail (App Password mã hóa) + state đồng bộ — KHÔNG commit
data/mails.json
data/mail-account.json
data/mail-sync.json

# Ưu tiên Deal AI — cache điểm/bảng (chứa tên + SĐT khách thật từ CRM) — KHÔNG commit
data/deal-cache.json

# Thẩm định Visa AI — kết quả + ảnh hồ sơ gốc (PII nhạy cảm) — KHÔNG commit
data/visa-assessments.json
data/visa-files/

# Chat-Analytics unresolved log (runtime state, có thể rotate) — KHÔNG commit
data/chat-unresolved.jsonl
data/chat-unresolved.jsonl.*

# Workflow debug trace log (runtime state, có thể rotate) — KHÔNG commit
data/workflow-traces.jsonl
data/workflow-traces.jsonl.*

# Tenant AI quota state (per-instance counters) — đè = mất counter đang chạy
data/tenant-quota.json

# Lead capture từ landing + visa (chứa SĐT/email khách lạ — KHÔNG commit, append-only)
data/consult-leads.jsonl
data/visa-leads.jsonl

# Dev server log + bất kỳ *.log nào (rotate được, không commit)
_server.log
*.log

# log4net output — rolling file appender ghi vào logs/app-YYYY-MM-DD.log + logs/error-*.log
# Rotate 30-90 file; append từ nhiều instance nên KHÔNG commit + KHÔNG mount volume chung khi scale.
logs/

# Audio test sample (binary, không phải source)
test-audio/

# wwwroot/bundle-entry.js: SOURCE file (esbuild đọc trực tiếp ở MSBuild target + build-frontend.ps1).
# PHẢI commit — deploy git-clone thiếu file này → esbuild fail / fallback dev mode (chậm).
# (dist/ vẫn ignore vì là build artifact — Dockerfile `dotnet publish -c Release` tự rebundle.)

# Tmp marker file dùng cho debug bash heredoc trên Windows (CP1252 lỗi)
_*.json
_*.txt
_*.xlsx

# AI usage log (rotation jsonl) — runtime state, có thể rotate
data/ai-usage.jsonl
data/ai-usage.jsonl.*

# MultiTenantMigration backup folders + .migrated artifacts
data/legacy-backup/
data/*.migrated

# Tmp folders (sample extracts, smoke logs)
tmp/
*smoketest.log

# E2E test artifacts (screenshots / reports / videos)
e2e/snap-*.png
e2e/report/
e2e/test-results/

# Playwright MCP runtime artifacts (snapshots .yml + console .log) + admin dev screenshots
.playwright-mcp/
admin-*.png

# Claude Code per-session scheduled-task lock
.claude/scheduled_tasks.lock

# Frontend bundle output (esbuild) — build artifact, run build-frontend.ps1.
# Co dist/ -> StaticFilesSetup auto switch sang prod-bundle mode (1 file, ~250KB).
# Khong co dist/ -> dev mode (35 file .jsx + Babel standalone, hot reload).
wwwroot/dist/

.gitnexus
gateway/.env
.claude-memory/.venv/
.claude-memory/scripts/state.json
