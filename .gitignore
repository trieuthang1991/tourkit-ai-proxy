data/tk-sessions.json

# API key provider nhập từ UI (mã hóa) — KHÔNG commit
data/provider-keys.json

# SmartMail AI — hộp thư cache + creds Gmail (App Password mã hóa) + state đồng bộ — KHÔNG commit
data/mails.json
data/mail-account.json
data/mail-sync.json

# Ưu tiên Deal AI — cache điểm/bảng (chứa tên + SĐT khách thật từ CRM) — KHÔNG commit
data/deal-cache.json

# Thẩm định Visa AI — kết quả + ảnh hồ sơ gốc (PII nhạy cảm) — KHÔNG commit
data/visa-assessments.json
data/visa-files/

# Chat-Analytics unresolved log (runtime state, có thể rotate) — KHÔNG commit
data/chat-unresolved.jsonl
data/chat-unresolved.jsonl.*

# Workflow debug trace log (runtime state, có thể rotate) — KHÔNG commit
data/workflow-traces.jsonl
data/workflow-traces.jsonl.*

# Tenant AI quota state (per-instance counters) — đè = mất counter đang chạy
data/tenant-quota.json

# Lead capture từ landing + visa (chứa SĐT/email khách lạ — KHÔNG commit, append-only)
data/consult-leads.jsonl
data/visa-leads.jsonl

# Dev server log + bất kỳ *.log nào (rotate được, không commit)
_server.log
*.log

# Audio test sample (binary, không phải source)
test-audio/

# Bundle entry stub (auto-gen từ build-frontend.ps1) — chứa generated content
wwwroot/bundle-entry.js

# Tmp marker file dùng cho debug bash heredoc trên Windows (CP1252 lỗi)
_*.json
_*.txt
_*.xlsx

# AI usage log (rotation jsonl) — runtime state, có thể rotate
data/ai-usage.jsonl
data/ai-usage.jsonl.*

# MultiTenantMigration backup folders + .migrated artifacts
data/legacy-backup/
data/*.migrated

# Tmp folders (sample extracts, smoke logs)
tmp/
