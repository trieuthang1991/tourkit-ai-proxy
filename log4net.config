<?xml version="1.0" encoding="utf-8"?>
<!--
  log4net config cho TourkitAiProxy (web) + TourkitAiProxy.Worker.
  Được wire vào ILogger<T> qua builder.Logging.AddLog4Net("log4net.config").
  Đổi <level> mà không cần restart: log4net watch file, hot reload.
-->
<log4net>
  <!-- ─── Appender 1: rolling file theo NGÀY (production log) ─────────────────
       - logs/app-YYYY-MM-DD.log
       - Giữ 30 file gần nhất (~1 tháng), file cũ tự xóa.
       - Layout kèm correlation ID (từ NDC) + tenant (từ ThreadContext) — hai
         key này set bởi middleware để mọi log trong 1 request có cùng tag.
  -->
  <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
    <file value="logs/app.log" />
    <appendToFile value="true" />
    <rollingStyle value="Date" />
    <datePattern value="'-'yyyy-MM-dd" />
    <staticLogFileName value="false" />
    <preserveLogFileNameExtension value="true" />
    <maxSizeRollBackups value="30" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{ISO8601} [%thread] %-5level %logger [req=%property{RequestId}|tenant=%property{TenantId}] - %message%newline%exception" />
    </layout>
  </appender>

  <!-- ─── Appender 2: rolling file RIÊNG cho ERROR (dễ tách khi cần audit) ───
       Filter chỉ nhận từ ERROR trở lên. Xoay theo ngày, giữ 90 file (~3 tháng).
  -->
  <appender name="ErrorFileAppender" type="log4net.Appender.RollingFileAppender">
    <file value="logs/error.log" />
    <appendToFile value="true" />
    <rollingStyle value="Date" />
    <datePattern value="'-'yyyy-MM-dd" />
    <staticLogFileName value="false" />
    <preserveLogFileNameExtension value="true" />
    <maxSizeRollBackups value="90" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <filter type="log4net.Filter.LevelRangeFilter">
      <levelMin value="ERROR" />
      <levelMax value="FATAL" />
    </filter>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{ISO8601} [%thread] %-5level %logger [req=%property{RequestId}|tenant=%property{TenantId}] - %message%newline%exception" />
    </layout>
  </appender>

  <!-- ─── Appender 3: console (dev/docker stdout) ─────────────────────────────
       Ngắn hơn (bỏ thread + logger dài) cho dev đọc dễ.
  -->
  <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{HH:mm:ss.fff} %-5level %logger{1} [req=%property{RequestId}] - %message%newline%exception" />
    </layout>
  </appender>

  <!-- ─── Root logger ─────────────────────────────────────────────────────────
       Level INFO ở prod (ít noise, đủ trace). Đổi DEBUG khi cần soi.
  -->
  <root>
    <level value="INFO" />
    <appender-ref ref="RollingFileAppender" />
    <appender-ref ref="ErrorFileAppender" />
    <appender-ref ref="ConsoleAppender" />
  </root>

  <!-- ─── Filter noise của ASP.NET Core / EF Core ─────────────────────────────
       Nâng lên WARNING để khỏi spam log request-lifecycle mặc định của Kestrel/
       Routing (đã có RequestLoggingMiddleware log gọn hơn).
  -->
  <logger name="Microsoft">
    <level value="WARN" />
  </logger>
  <logger name="Microsoft.Hosting.Lifetime">
    <level value="INFO" />
  </logger>
  <logger name="System.Net.Http.HttpClient">
    <level value="WARN" />
  </logger>

  <!-- ─── App-specific tuning ────────────────────────────────────────────────
       TourkitAiProxy.* mặc định theo root (INFO). Bật DEBUG cho namespace cụ thể
       để soi khi cần (không đụng root).
  -->
  <!--
  <logger name="TourkitAiProxy.Services.Workflows">
    <level value="DEBUG" />
  </logger>
  -->
</log4net>
