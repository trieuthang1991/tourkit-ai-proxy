# /opt/vbee-gateway/.env — copy từ file này, điền giá trị thật, chmod 600
# KHÔNG commit file .env thật.

# Cổng nội bộ Node lắng nghe (nginx proxy vào đây); chỉ 127.0.0.1
PORT=8090
HOST=127.0.0.1

# Khóa chia sẻ: Windows proxy phải gửi header  X-Api-Key: <đúng giá trị này>
# Sinh 1 chuỗi ngẫu nhiên mạnh:  openssl rand -hex 32
GATEWAY_API_KEY=REPLACE_WITH_RANDOM_32_BYTES_HEX

# Tài khoản Vbee (chỉ nằm ở gateway này — không lộ ra Windows)
VBEE_APP_ID=REPLACE_WITH_VBEE_APP_ID
VBEE_TOKEN=REPLACE_WITH_VBEE_TOKEN

# Tùy chọn (mặc định đã hợp lý)
VBEE_VOICE=hn_female_ngochuyen_full_48k-fhg
VBEE_SAMPLE_RATE=24000
VBEE_BITRATE=128
VBEE_SPEED=1.0
VBEE_POLL_TIMEOUT=45
VBEE_WEBHOOK_URL=https://tourkit.vn/vbee-callback
