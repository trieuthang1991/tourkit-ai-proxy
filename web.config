<?xml version="1.0" encoding="utf-8"?>
<!--
  Template web.config cho IIS deployment.

  IIS mặc định CÀI WebDAV module → "ăn" hết DELETE/PUT/PATCH/OPTIONS requests
  rồi trả 405 Method Not Allowed cho app. Phải REMOVE module + handler.

  Khi `dotnet publish` chạy:
  - File này được copy vào output/
  - Publisher tự cập nhật <aspNetCore> attributes (processPath, arguments, version)
  - Các remove WebDAV / handler khác được giữ nguyên

  Sửa thẳng trên server: cũng OK, copy block <modules>/<handlers> vào web.config
  tự sinh rồi `iisreset`.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- Gỡ WebDAV cho mọi method (POST/PUT/DELETE/PATCH chạy bình thường) -->
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\TourkitAiProxy.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      <!-- Cho phép file >30MB upload (PDF/ZIP hồ sơ visa); khớp với Kestrel 300MB ở Program.cs -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="314572800" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
